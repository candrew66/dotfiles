#!/bin/sh

# Get command line arguments
help= port= repo= ssh=
while getopts 'hp:r:s' OPTION; do
	case "$OPTION" in
		h) help=1 && shift					;;
		p) ssh=1 port="$OPTARG" && shift 2	;;
		r) repo="--repo=$OPTARG" && shift 2	;;
		s) ssh=1 && shift					;;
	esac
done

# Show help message
if [ -n "$help" -o $# -eq 0 ]; then
	echo "Usage: $(basename $0) [options] directory/host

Create package lists and backup directory.

Options:
 -h		Show this message
 -p PORT 	SSH port number (includes -s)
 -r REPOSITORY	Restic repository to backup to
 -s		Backup home folder from SSH host"
	[ -n "$help" ] && exit || exit 1
fi

# Create package lists
if [ -n "$ssh" ]; then
	# Set SSH port if port flag was passed
	[ -n "$port" ] && ssh_port="-p $port"

	ssh $ssh_port "$1" "sh -lc pkgbackup"
else
	pkgbackup
fi

# Setup sftp host if ssh flag was passed
backup_dir="$1"
if [ -n "$ssh" ]; then
	backup_dir=~/.local/mnt
	mkdir -p "$backup_dir"

	# Set SFTP port if port flag was passed
	[ -n "$port" ] && sftp_port="--sftp-port=$port"

	rclone mount --sftp-host "$1" "$sftp_port" :sftp: "$backup_dir" --daemon --read-only
fi

# Backup directory
restic backup "$backup_dir" "$repo" --exclude-file "${XDG_CONFIG_HOME:-$HOME/.config}/restic/exclude.list"

# Clean up sftp mountpoint if ssh flag was passed
if [ -n "$ssh" ]; then
	fusermount3 -u "$backup_dir"
	rm -r "$backup_dir"
fi
