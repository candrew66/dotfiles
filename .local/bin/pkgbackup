#!/bin/sh -eu

# Get command line arguments
help= pkglist_dir=~/.config/packages
while getopts 'hp:' OPTION; do
	case "$OPTION" in
		h) help=1							;;
		p) pkglist_dir=$OPTARG && shift 2	;;
	esac
done

# Show help message
if [ -n "$help" ]; then
	echo "Usage: $(basename $0) [options]

Create package lists.

Options:
 -h		Show this message
 -p DIRECTORY	Package list directory"
	exit
fi

# Create package lists
mkdir -p "$pkglist_dir"
type apt >/dev/null && apt-mark showmanual > "$pkglist_dir/apt" # Debian (apt) packages
type flatpak >/dev/null && flatpak list --app --columns=ref > "$pkglist_dir/flatpak" # Flatpak apps
